{
  "lastChangelogVersion": "0.79.8",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "theme": "catppuccin-frappe",
  "packages": [
    "npm:pi-subagents",
    "npm:pi-show-diffs",
    "npm:pi-tool-display",
    "npm:pi-image-tools"
  ],
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium"
      },
      "context-builder": {
        "model": "deepseek/deepseek-v4-pro",
        "thinking": "high"
      },
      "planner": {
        "model": "deepseek/deepseek-v4-pro",
        "thinking": "high"
      },
      "oracle": {
        "model": "deepseek/deepseek-v4-pro",
        "thinking": "high"
      },
      "worker": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "high"
      },
      "reviewer": {
        "model": "deepseek/deepseek-v4-pro",
        "thinking": "high",
        "fallbackModels": [
          "openai-codex/gpt-5.4"
        ]
      }
    }
  }
}