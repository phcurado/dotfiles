{
  "lastChangelogVersion": "0.80.6",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "medium",
  "theme": "catppuccin-frappe",
  "outputPad": 0,
  "markdown": {
    "codeBlockIndent": ""
  },
  "packages": [
    "npm:pi-subagents",
    "npm:pi-show-diffs",
    "npm:pi-tool-display",
    "npm:pi-image-tools",
    "npm:@mohndoe/pi-atlas"
  ],
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium"
      },
      "context-builder": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium"
      },
      "planner": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "high"
      },
      "oracle": {
        "model": "openai-codex/gpt-5.4",
        "thinking": "high"
      },
      "worker": {
        "model": "openai-codex/gpt-5.4",
        "thinking": "high"
      },
      "reviewer": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium",
        "fallbackModels": [
          "openai-codex/gpt-5.4"
        ]
      },
      "researcher": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium"
      },
      "delegate": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium"
      }
    }
  }
}
