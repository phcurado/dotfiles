#!/usr/bin/env sh
set -eu

window_id="${1:?}"
path="${2:-$HOME}"
hidden_session="__agent-sidebar"

visible_pane="$(tmux list-panes -t "$window_id" -F '#{pane_id}|#{@agent_sidebar}|#{@agent_sidebar_home}' | awk -F '|' -v home="$window_id" '$2 == "1" && $3 == home { print $1; exit }')"

if [ -n "$visible_pane" ]; then
  if [ "$(tmux display-message -p -t "$visible_pane" '#{@pi_approval}')" = "1" ]; then
    tmux display-message -t "$visible_pane" 'approval active'
    exit 0
  fi

  if ! tmux has-session -t "$hidden_session" 2> /dev/null; then
    tmux new-session -d -s "$hidden_session" -n scratch -c "$path"
    created_session=1
  else
    created_session=0
  fi

  tmux break-pane -d -s "$visible_pane" -t "$hidden_session:" -n agent-sidebar > /dev/null

  if [ "$created_session" = 1 ]; then
    tmux kill-window -t "$hidden_session:scratch" 2> /dev/null || true
  fi

  exit 0
fi

hidden_pane="$(tmux list-panes -a -F '#{pane_id}|#{window_id}|#{@agent_sidebar}|#{@agent_sidebar_home}' | awk -F '|' -v home="$window_id" '$3 == "1" && $4 == home { print $1; exit }')"

target_pane="$(tmux list-panes -t "$window_id" -F '#{pane_id}|#{@agent_sidebar}|#{@bottom_terminal}' | awk -F '|' '$2 != "1" && $3 != "1" { print $1; exit }')"

if [ -n "$hidden_pane" ] && [ -n "$target_pane" ]; then
  tmux join-pane -h -l 35% -s "$hidden_pane" -t "$target_pane"
  tmux select-pane -t "$hidden_pane"
  exit 0
fi

pane_id="$(tmux split-window -h -l 35% -d -P -F '#{pane_id}' -t "${target_pane:-$window_id}" -c "$path" 'pi')"
tmux set-option -pt "$pane_id" @agent_sidebar 1
tmux set-option -pt "$pane_id" @agent_sidebar_home "$window_id"
tmux select-pane -t "$pane_id" -T agent
tmux select-pane -t "$pane_id"
