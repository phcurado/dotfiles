#!/usr/bin/env sh
set -eu

window_id="${1:?}"
path="${2:-$HOME}"
hidden_session="__agent-sidebar"

active_pane="$(tmux display-message -p -t "$window_id" '#{pane_id}')"
if [ "$(tmux display-message -p -t "$window_id" '#{window_zoomed_flag}')" = "1" ]; then
  tmux resize-pane -Z -t "$active_pane"
fi

visible_pane="$(tmux list-panes -t "$window_id" -F '#{pane_id}|#{@bottom_terminal}|#{@bottom_terminal_home}' | awk -F '|' -v home="$window_id" '$2 == "1" && $3 == home { print $1; exit }')"

if [ -n "$visible_pane" ]; then
  if ! tmux has-session -t "$hidden_session" 2> /dev/null; then
    tmux new-session -d -s "$hidden_session" -n scratch -c "$path"
    created_session=1
  else
    created_session=0
  fi

  tmux break-pane -d -s "$visible_pane" -t "$hidden_session:" -n bottom-terminal > /dev/null

  if [ "$created_session" = 1 ]; then
    tmux kill-window -t "$hidden_session:scratch" 2> /dev/null || true
  fi

  exit 0
fi

hidden_pane="$(tmux list-panes -a -F '#{pane_id}|#{window_id}|#{@bottom_terminal}|#{@bottom_terminal_home}' | awk -F '|' -v home="$window_id" '$3 == "1" && $4 == home { print $1; exit }')"
target_pane="$(tmux list-panes -t "$window_id" -F '#{pane_id}|#{@agent_sidebar}|#{@bottom_terminal}' | awk -F '|' '$2 != "1" && $3 != "1" { print $1; exit }')"

if [ -n "$hidden_pane" ] && [ -n "$target_pane" ]; then
  tmux join-pane -v -l 30% -s "$hidden_pane" -t "$target_pane"
  tmux select-pane -t "$hidden_pane"
  exit 0
fi

pane_id="$(tmux split-window -v -l 30% -d -P -F '#{pane_id}' -t "${target_pane:-$window_id}" -c "$path")"
tmux set-option -pt "$pane_id" @bottom_terminal 1
tmux set-option -pt "$pane_id" @bottom_terminal_home "$window_id"
tmux select-pane -t "$pane_id" -T tests
tmux select-pane -t "$pane_id"
